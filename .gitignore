# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.*
*.env
venv/
.venv/
env/
miniforge/
conda-meta/

# ── Data — large binary files, never commit raw data ─────────────────────────
data/raw/
data/features/
data/macro/
data/cache/

# ── ML artefacts — too large for git, rebuilt by pipeline ────────────────────
models/*.pkl
models/*.model
mlflow.db
mlflow.db-shm
mlflow.db-wal
mlruns/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Notebooks ────────────────────────────────────────────────────────────────
notebooks/charts/
notebooks/exports/
notebooks/.ipynb_checkpoints/
*.ipynb

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Streamlit ────────────────────────────────────────────────────────────────
# Keep .streamlit/config.toml (theme) but never secrets
.streamlit/secrets.toml

# ── On-demand cache — large, rebuilt on first run, not needed in repo ─────────
dashboard/cache/on_demand/

# ── KEEP these (explicitly un-ignore) ────────────────────────────────────────
# dashboard/cache/execution_plan.json  ← committed by GitHub Actions each month
# results/portfolio_simulation.json   ← committed by GitHub Actions each month
# models/*_backtest.csv               ← small, useful for Evidence tab
# models/backtest_summary.json        ← small summary
