# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.*
*.env
venv/
.venv/
env/
miniforge/
conda-meta/

# ── Data — large binary files, never commit raw data ─────────────────────────
data/raw/
data/features/
data/macro/
data/cache/

# ── ML artefacts ─────────────────────────────────────────────────────────────
# PKL files ARE committed (2-3MB each, 61MB total — fine for GitHub)
# They are required on Streamlit Cloud since the pipeline can't retrain there
# models/*.pkl  <-- intentionally NOT excluded

mlflow.db
mlflow.db-shm
mlflow.db-wal
mlruns/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Notebooks ────────────────────────────────────────────────────────────────
notebooks/charts/
notebooks/exports/
notebooks/.ipynb_checkpoints/
*.ipynb

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Streamlit ────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── On-demand cache — large, rebuilt on first user request ───────────────────
dashboard/cache/on_demand/
models/*.pkl
models/*.csv
models/robustness_report.json
models/reasons_3_4_report.json
